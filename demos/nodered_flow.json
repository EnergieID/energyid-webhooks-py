    {
        "id": "eid_func_check",
        "type": "function",
        "z": "eid_flow_tab",
        "g": "eid_group_data",
        "name": "Check Response",
        "func": "var code = msg.statusCode;\n\nmsg.result = {\n    statusCode: code,\n    body: msg.payload,\n    url: msg.url || \"(from msg.url)\"\n};\n\nif (code === 201 || code === 200) {\n    node.status({ fill: \"green\", shape: \"dot\", text: \"OK (\" + code + \")\" });\n    return [msg, null, null];\n}\n\nif (code === 401) {\n    node.status({ fill: \"red\", shape: \"ring\", text: \"401 - Re-authenticating...\" });\n    node.warn(\"Token expired - auto re-authenticating...\");\n    flow.set(\"webhookUrl\", null);\n    flow.set(\"webhookHeaders\", null);\n    return [null, msg, msg];\n}\n\nif (code === 400) {\n    node.status({ fill: \"orange\", shape: \"dot\", text: \"400 - Bad payload\" });\n    node.warn(\"Bad request - check your payload format: \" + JSON.stringify(msg.payload));\n    return [null, msg, null];\n}\n\nif (code === 429) {\n    node.status({ fill: \"orange\", shape: \"ring\", text: \"429 - Rate limited\" });\n    node.warn(\"Rate limited! Upload interval: \" + flow.get(\"uploadInterval\") + \"s\");\n    return [null, msg, null];\n}\n\nnode.status({ fill: \"red\", shape: \"dot\", text: \"Error \" + code });\nnode.warn(\"HTTP \" + code + \": \" + JSON.stringify(msg.payload));\nreturn [null, msg, null];",
        "outputs": 3,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
