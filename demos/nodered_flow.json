        "type": "function",
        "z": "eid_flow_tab",
        "g": "eid_group_device2",
        "name": "Device 2 Credentials",
        "func": "msg.headers = {\n    \"Content-Type\": \"application/json\",\n    \"X-Provisioning-Key\": env.get(\"ENERGYID_PROVISIONING_KEY\"),\n    \"X-Provisioning-Secret\": env.get(\"ENERGYID_PROVISIONING_SECRET\")\n};\n\n// Different deviceId for the second device\nmsg.payload = {\n    \"deviceId\": \"nodered_device_002\",\n    \"deviceName\": \"Node-RED Device 2\"\n};\n\nmsg.url = \"https://hooks.energyid.eu/hello\";\n\nnode.status({ fill: \"blue\", shape: \"dot\", text: \"Authenticating Device 2...\" });\nreturn msg;",
