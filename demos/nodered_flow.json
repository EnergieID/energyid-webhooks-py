    {
        "id": "eid_claim_counter",
        "type": "function",
        "z": "eid_flow_tab",
        "g": "eid_group_auth",
        "name": "Claim Retry Counter",
        "func": "var retries = flow.get(\"claim_retries\") || 0;\nretries++;\nflow.set(\"claim_retries\", retries);\n\nif (retries > 20) {\n    node.status({ fill: \"red\", shape: \"dot\", text: \"Max retries (\" + retries + \")\" });\n    node.warn(\"Claim retry limit reached. Claim your device at the claimUrl shown in the debug panel.\");\n    return null;\n}\n\nnode.status({ fill: \"yellow\", shape: \"ring\", text: \"Retry \" + retries + \"/20\" });\nreturn msg;",
