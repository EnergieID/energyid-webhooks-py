    {
        "id": "eid_d2_func_store",
        "type": "function",
        "z": "eid_flow_tab",
        "g": "eid_group_device2",
        "name": "Store Device 2 Creds",
        "func": "var body = msg.payload;\nvar status = msg.statusCode;\n\nif (status !== 200) {\n    node.status({ fill: \"red\", shape: \"dot\", text: \"HTTP \" + status });\n    node.warn(\"Device 2 hello failed: HTTP \" + status);\n    return [null, msg];\n}\n\nif (body.webhookUrl && body.headers) {\n    flow.set(\"device2_webhookUrl\", body.webhookUrl);\n    flow.set(\"device2_webhookHeaders\", body.headers);\n    node.status({ fill: \"green\", shape: \"dot\", text: \"OK - \" + (body.recordName || \"claimed\") });\n    msg.parsed = {\n        webhookUrl: body.webhookUrl,\n        recordName: body.recordName,\n        recordNumber: body.recordNumber\n    };\n    return [msg, null];\n} else {\n    node.status({ fill: \"yellow\", shape: \"ring\", text: \"Claim required\" });\n    return [null, msg];\n}",
