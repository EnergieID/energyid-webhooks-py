    {
        "id": "eid_batch_func_collect",
        "type": "function",
        "z": "eid_flow_tab",
        "g": "eid_group_batch",
        "name": "Collect Reading",
        "func": "// Simulate a sensor reading (replace with your actual sensor input)\nvar reading = {\n    \"ts\": Math.floor(Date.now() / 1000),\n    \"el\": Math.round(Math.random() * 100 + 12300),\n    \"gas\": Math.round(Math.random() * 10 + 450)\n};\n\n// Add to buffer\nvar buffer = flow.get(\"batch_buffer\") || [];\nbuffer.push(reading);\nflow.set(\"batch_buffer\", buffer);\n\nnode.status({ fill: \"blue\", shape: \"ring\", text: buffer.length + \" readings buffered\" });\nmsg.payload = reading;\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
