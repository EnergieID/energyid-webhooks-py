    {
        "id": "eid_func_build_data",
        "type": "function",
        "z": "eid_flow_tab",
        "g": "eid_group_data",
        "name": "Build Data POST",
        "func": "var url = flow.get(\"webhookUrl\");\nvar hdrs = flow.get(\"webhookHeaders\");\n\nif (!url || !hdrs) {\n    node.status({ fill: \"red\", shape: \"ring\", text: \"Not authenticated\" });\n    node.error(\"Not authenticated yet - click Authenticate first\");\n    return null;\n}\n\n// Set URL from stored /hello response\nmsg.url = url;\n\n// Pass through auth headers exactly as received from /hello\nmsg.headers = {\n    \"authorization\": hdrs[\"authorization\"],\n    \"x-twin-id\": hdrs[\"x-twin-id\"],\n    \"Content-Type\": \"application/json\"\n};\n\n// =============================================\n// EDIT YOUR SENSOR DATA BELOW\n// Predefined keys: el, gas, pv, water, etc.\n// ts = unix timestamp in seconds (mandatory)\n// =============================================\nmsg.payload = {\n    \"ts\": Math.floor(Date.now() / 1000),\n    \"gas\": 456\n};\n\nnode.status({ fill: \"blue\", shape: \"dot\", text: \"Sending to \" + url.substring(0, 40) + \"...\" });\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
