    {
        "id": "eid_batch_func_build",
        "type": "function",
        "z": "eid_flow_tab",
        "g": "eid_group_batch",
        "name": "Build Batch Payload",
        "func": "var url = flow.get(\"webhookUrl\");\nvar hdrs = flow.get(\"webhookHeaders\");\n\nif (!url || !hdrs) {\n    node.status({ fill: \"red\", shape: \"ring\", text: \"Not authenticated\" });\n    node.error(\"Not authenticated - run Authenticate first\");\n    return null;\n}\n\nvar buffer = flow.get(\"batch_buffer\") || [];\nif (buffer.length === 0) {\n    node.status({ fill: \"grey\", shape: \"ring\", text: \"Buffer empty\" });\n    return null;\n}\n\n// Clear buffer before sending\nflow.set(\"batch_buffer\", []);\n\nmsg.url = url;\nmsg.headers = {\n    \"authorization\": hdrs[\"authorization\"],\n    \"x-twin-id\": hdrs[\"x-twin-id\"],\n    \"Content-Type\": \"application/json\"\n};\n\n// Send as array of readings - each with its own timestamp\nmsg.payload = buffer;\n\nnode.status({ fill: \"blue\", shape: \"dot\", text: \"Sending \" + buffer.length + \" readings...\" });\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
