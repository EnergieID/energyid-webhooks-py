    {
        "id": "eid_func_store",
        "type": "function",
        "z": "eid_flow_tab",
        "g": "eid_group_auth",
        "name": "Parse & Store Credentials",
        "func": "var body = msg.payload;\nvar status = msg.statusCode;\n\nif (status !== 200) {\n    node.status({ fill: \"red\", shape: \"dot\", text: \"HTTP \" + status });\n    node.warn(\"Hello failed: HTTP \" + status + \" - \" + JSON.stringify(body));\n    return [null, msg];\n}\n\nif (body.webhookUrl && body.headers) {\n    // Device is claimed - store credentials\n    flow.set(\"webhookUrl\", body.webhookUrl);\n    flow.set(\"webhookHeaders\", body.headers);\n    flow.set(\"recordName\", body.recordName);\n    flow.set(\"recordNumber\", body.recordNumber);\n    flow.set(\"uploadInterval\", body.webhookPolicy ? body.webhookPolicy.uploadInterval : 60);\n    flow.set(\"claim_retries\", 0);\n\n    node.status({ fill: \"green\", shape: \"dot\", text: \"OK - \" + body.recordName });\n\n    // Build a clean summary for debug\n    msg.parsed = {\n        webhookUrl: body.webhookUrl,\n        authorization: body.headers.authorization ? body.headers.authorization.substring(0, 60) + \"...\" : \"MISSING\",\n        \"x-twin-id\": body.headers[\"x-twin-id\"],\n        recordName: body.recordName,\n        recordNumber: body.recordNumber,\n        uploadInterval: body.webhookPolicy ? body.webhookPolicy.uploadInterval : \"unknown\"\n    };\n\n    return [msg, null];\n} else {\n    // Device not claimed\n    node.status({ fill: \"yellow\", shape: \"ring\", text: \"Claim required\" });\n    return [null, msg];\n}",
        "outputs": 2,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
