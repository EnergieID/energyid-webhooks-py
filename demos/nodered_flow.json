        "id": "eid_func_provisioning",
        "type": "function",
        "z": "eid_flow_tab",
        "g": "eid_group_auth",
        "name": "Set Provisioning Credentials",
        "func": "msg.headers = {\n    \"Content-Type\": \"application/json\",\n    \"X-Provisioning-Key\": env.get(\"ENERGYID_PROVISIONING_KEY\"),\n    \"X-Provisioning-Secret\": env.get(\"ENERGYID_PROVISIONING_SECRET\")\n};\n\nmsg.payload = {\n    \"deviceId\": env.get(\"ENERGYID_DEVICE_ID\") || \"nodered_device_001\",\n    \"deviceName\": env.get(\"ENERGYID_DEVICE_NAME\") || \"Node-RED Device\"\n};\n\nmsg.url = \"https://hooks.energyid.eu/hello\";\n\nnode.status({ fill: \"blue\", shape: \"dot\", text: \"Authenticating...\" });\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
